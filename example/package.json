{
  "name": "kysely-example",
  "version": "1.0.0",
  "type": "module",
  "description": "A modern example app demonstrating Kysely with a Northwind-inspired schema",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/migrate.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "hono": "^4.7.6",
    "jose": "^6.0.11",
    "kysely": "^0.28.0",
    "pg": "^8.13.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}